+bool RadioRecoverTxWithOrigin( uint32_t origin )
+{
+    if( ( origin == 0 ) || !RadioTryClaimIrqRecovery( ) )
+    {
+        return false;
+    }
+    if( __atomic_load_n( &RadioTxOrigin, __ATOMIC_ACQUIRE ) != origin )
+    {
+        RadioReleaseIrqRecovery( );
+        return false;
+    }
