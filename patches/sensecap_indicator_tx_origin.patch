+    /* The watchdog owns this exact transmission. Quiesce the SX1262 and
+     * acknowledge both the radio IRQ and the TCA9535 input latch before the
+     * runtime can admit a successor. Queued stale board events then observe
+     * DIO1 low and cannot consume a later transmission's terminal IRQ. */
+    TimerStop( &TxTimeoutTimer );
+    RadioStandby( );
+    SX126xClearIrqStatus( IRQ_RADIO_ALL );
+    ( void )SX126xGetDio1PinState( );
+    RadioTxTimeoutOrigin = 0;
+    RadioIrqTxOrigin = 0;
+    IrqFired = false;
+    __atomic_store_n( &RadioTxOrigin, 0, __ATOMIC_RELEASE );
+    RadioReleaseIrqRecovery( );
+    return true;
+}
 
