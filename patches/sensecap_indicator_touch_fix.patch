diff --git a/components/bsp/src/indev/indev.c b/components/bsp/src/indev/indev.c
index 2b8aa91..6a82a4f 100644
--- a/components/bsp/src/indev/indev.c
+++ b/components/bsp/src/indev/indev.c
@@ -71,2 +71,4 @@ esp_err_t indev_get_major_value(indev_data_t *data)
-    uint16_t x, y;
-    uint8_t tp_num, btn_val;
+    uint16_t x = 0;
+    uint16_t y = 0;
+    uint8_t tp_num = 0;
+    uint8_t btn_val = 0;
@@ -79,0 +82 @@ esp_err_t indev_get_major_value(indev_data_t *data)
+            bool pressed = (tp_num > 0) || (btn_val != 0);
@@ -82,6 +85,2 @@ esp_err_t indev_get_major_value(indev_data_t *data)
-            data->btn_val = btn_val;
-            if (tp_num > 0) {
-                data->pressed = true;
-            } else {
-                data->pressed = false;
-            }
+            data->btn_val = pressed ? 1 : 0;
+            data->pressed = pressed;
@@ -90,0 +90,2 @@ esp_err_t indev_get_major_value(indev_data_t *data)
+            data->btn_val = 0;
+            data->pressed = false;
diff --git a/components/bsp/src/indev/indev_tp.c b/components/bsp/src/indev/indev_tp.c
