+                 tp_dev_list[0].dev_addr, tp_dev_list[0].dev_name);
+    }
@@ -84 +88,4 @@ esp_err_t indev_tp_init(void)
-        ret_val |= tp_prob(&tp_dev_id);
+        ret_val = tp_prob(&tp_dev_id);
+        if (ret_val != ESP_OK) {
+            return ret_val;
+        }
