diff --git a/components/bsp/src/indev/indev.c b/components/bsp/src/indev/indev.c
index 2b8aa91..6a82a4f 100644
--- a/components/bsp/src/indev/indev.c
+++ b/components/bsp/src/indev/indev.c
@@ -45,3 +45,4 @@ esp_err_t indev_init_default(void)
-        if (ESP_OK == ret) {
+        if (ESP_OK == ret || ESP_ERR_INVALID_STATE == ret) {
             g_major_dev = BSP_INDEV_TP;
+            ret = ESP_OK;
         }
@@ -71,2 +71,4 @@ esp_err_t indev_get_major_value(indev_data_t *data)
-    uint16_t x, y;
-    uint8_t tp_num, btn_val;
+    uint16_t x = 0;
+    uint16_t y = 0;
+    uint8_t tp_num = 0;
+    uint8_t btn_val = 0;
@@ -80,0 +84 @@ esp_err_t indev_get_major_value(indev_data_t *data)
+            bool pressed = (tp_num > 0) || (btn_val != 0);
@@ -82,6 +85,2 @@ esp_err_t indev_get_major_value(indev_data_t *data)
-            data->btn_val = btn_val;
-            if (tp_num > 0) {
-                data->pressed = true;
-            } else {
-                data->pressed = false;
-            }
+            data->btn_val = pressed ? 1 : 0;
+            data->pressed = pressed;
@@ -90,0 +90,2 @@ esp_err_t indev_get_major_value(indev_data_t *data)
+            data->btn_val = 0;
+            data->pressed = false;
diff --git a/components/bsp/src/indev/indev_tp.c b/components/bsp/src/indev/indev_tp.c
index b57ece5..d3f6dd3 100644
--- a/components/bsp/src/indev/indev_tp.c
+++ b/components/bsp/src/indev/indev_tp.c
@@ -56 +56 @@ static esp_err_t tp_prob(int *tp_dev_id)
-                *tp_dev_id = tp_dev_list[i].dev_vendor;
+                *tp_dev_id = (int)i;
@@ -63 +63 @@ static esp_err_t tp_prob(int *tp_dev_id)
-            *tp_dev_id = tp_dev_list[i].dev_vendor;
+            *tp_dev_id = (int)i;
@@ -80 +80,5 @@ esp_err_t indev_tp_init(void)
-    tp_dev_id = TP_VENDOR_FT;
+    if (ESP_OK == bsp_i2c_probe_addr(tp_dev_list[0].dev_addr)) {
+        tp_dev_id = 0;
+        ESP_LOGI(TAG, "Detected touch panel at 0x%02X. Vendor : %s",
+                 tp_dev_list[0].dev_addr, tp_dev_list[0].dev_name);
+    }
@@ -84 +88,4 @@ esp_err_t indev_tp_init(void)
-        ret_val |= tp_prob(&tp_dev_id);
+        ret_val = tp_prob(&tp_dev_id);
+        if (ret_val != ESP_OK) {
+            return ret_val;
+        }
diff --git a/components/i2c_devices/touch_panel/ft5x06.c b/components/i2c_devices/touch_panel/ft5x06.c
index dfb2cf1..0b52b7a 100644
--- a/components/i2c_devices/touch_panel/ft5x06.c
+++ b/components/i2c_devices/touch_panel/ft5x06.c
@@ -93 +93 @@ esp_err_t ft5x06_init(void)
-        return ESP_ERR_INVALID_STATE;
+        return ESP_OK;
@@ -104,26 +104,2 @@ esp_err_t ft5x06_init(void)
-    // Valid touching detect threshold
-    i2c_bus_write_byte(ft5x06_handle, FT5x06_ID_G_THGROUP, 70);
-
-    // valid touching peak detect threshold
-    i2c_bus_write_byte(ft5x06_handle, FT5x06_ID_G_THPEAK, 60);
-
-    // Touch focus threshold
-    i2c_bus_write_byte(ft5x06_handle, FT5x06_ID_G_THCAL, 16);
-
-    // threshold when there is surface water
-    i2c_bus_write_byte(ft5x06_handle, FT5x06_ID_G_THWATER, 60);
-
-    // threshold of temperature compensation
-    i2c_bus_write_byte(ft5x06_handle, FT5x06_ID_G_THTEMP, 10);
-
-    // Touch difference threshold
-    i2c_bus_write_byte(ft5x06_handle, FT5x06_ID_G_THDIFF, 20);
-
-    // Delay to enter 'Monitor' status (s)
-    i2c_bus_write_byte(ft5x06_handle, FT5x06_ID_G_TIME_ENTER_MONITOR, 2);
-
-    // Period of 'Active' status (ms)
-    i2c_bus_write_byte(ft5x06_handle, FT5x06_ID_G_PERIODACTIVE, 12);
-
-    // Timer to enter 'idle' when in 'Monitor' (ms)
-    i2c_bus_write_byte(ft5x06_handle, FT5x06_ID_G_PERIODMONITOR, 40);
+    ret_val |= ft5x06_write_byte(FT5x06_DEVICE_MODE, 0x00);
+    ret_val |= ft5x06_write_byte(FT5x06_ID_G_PMODE, 0x00);
@@ -131 +107 @@ esp_err_t ft5x06_init(void)
-    return ESP_OK;
+    return ret_val;
@@ -136 +112,8 @@ static esp_err_t ft5x06_get_touch_points_num(uint8_t *touch_points_num)
-    return ft5x06_read_byte(FT5x06_TOUCH_POINTS, touch_points_num);
+    esp_err_t ret = ft5x06_read_byte(FT5x06_TOUCH_POINTS, touch_points_num);
+    if (ret == ESP_OK) {
+        *touch_points_num &= 0x0f;
+        if (*touch_points_num > 5) {
+            *touch_points_num = 0;
+        }
+    }
+    return ret;
